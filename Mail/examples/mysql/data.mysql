use mailsys;

-- domains
insert into virtual_domains(`name`) values('example.org');

-- user info
insert into virtual_users(`domain_id`,`password`,`salt`,`email`) values (1,TO_BASE64(UNHEX(concat(SHA2(CONCAT('psaaword', UNHEX('ffffff')), 512), 'ffffff'))),'ffffff','user1@example.org');

-- virtual_aliases
insert into virtual_aliases(`domain_id`,`source`,`destination`) values (1,'user2@example.org','user1@example.org');
